# Copy to .env and adjust if needed. docker-compose reads this file automatically.
# These are HOST-side ports (left of the `:` in compose port mappings) — chosen
# to avoid clashing with a Postgres/Redis you might already have running locally.

POSTGRES_DB=event_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

REDIS_PORT=6380

API_PORT=8080

DASHBOARD_PORT=5173
VITE_API_URL=http://localhost:8080

# Used when running `npm test`/`npm run migrate` from the host machine (outside
# docker-compose) against the containers above.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/event_analytics
REDIS_URL=redis://localhost:6380
